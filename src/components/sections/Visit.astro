---
import Icon from "../Icon.astro";
import { salon } from "../../data/salon";
---

<section id="bezoek" class="py-24 md:py-32">
  <div class="container-prohair">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12">
      <div class="lg:col-span-5" data-reveal>
        <p class="eyebrow mb-5">Bezoek de salon</p>
        <h2 class="font-display text-[40px] sm:text-[56px] md:text-[64px] leading-[0.98]">
          Kabelweg 20,<br/>
          <em class="italic text-copper">Vlissingen.</em>
        </h2>
        <p class="mt-6 text-ink-soft text-[15px] leading-[1.7] max-w-md">
          Aan de rand van het centrum, vijf minuten lopen van station Vlissingen en met gratis parkeren voor de deur.
        </p>

        <div class="mt-8 space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-cream-2 inline-flex items-center justify-center shrink-0"><Icon name="pin" size={18}/></div>
            <div>
              <p class="text-[11px] uppercase tracking-[0.16em] text-ink-soft">Adres</p>
              <p class="text-[15px]">{salon.address.street}<br/>{salon.address.zip} {salon.address.city}</p>
              <a href={salon.mapsUrl} target="_blank" rel="noopener" class="text-[13px] text-copper-deep hover:underline mt-1 inline-block">Route plannen</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-cream-2 inline-flex items-center justify-center shrink-0"><Icon name="phone" size={18}/></div>
            <div>
              <p class="text-[11px] uppercase tracking-[0.16em] text-ink-soft">Bellen</p>
              <a href={salon.phoneHref} class="text-[15px] hover:text-copper-deep">{salon.phone}</a>
              <p class="text-[13px] text-ink-soft mt-1">Wij nemen op tijdens openingsuren.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-cream-2 inline-flex items-center justify-center shrink-0"><Icon name="clock" size={18}/></div>
            <div>
              <p class="text-[11px] uppercase tracking-[0.16em] text-ink-soft">Openingstijden</p>
              <ul class="text-[14px] mt-1 space-y-0.5">
                {salon.hours.map((h) => (
                  <li class={`flex justify-between gap-6 ${h.closed ? 'text-ink-soft' : ''}`}>
                    <span>{h.day}</span><span>{h.time}{h.note ? ` (${h.note})` : ''}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7" data-reveal>
        <div class="relative aspect-[4/3] md:aspect-[5/4] rounded-jumbo overflow-hidden bg-cream-2 image-grain">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2520.0!2d3.5731!3d51.4516!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sKabelweg%2020%2C%204382%20WV%20Vlissingen!5e0!3m2!1snl!2snl"
            class="w-full h-full grayscale-[60%] contrast-105"
            style="filter: hue-rotate(-10deg) saturate(70%);"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            title="ProHair locatie kaart"
          ></iframe>
          <div class="absolute top-5 left-5 right-5 flex items-center justify-between">
            <div class="bg-cream/95 backdrop-blur rounded-full px-4 py-2.5 text-[12px] flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
              Nu geopend
            </div>
            <a href={salon.mapsUrl} target="_blank" rel="noopener" class="bg-ink text-cream rounded-full px-4 py-2.5 text-[12px] hover:bg-copper-deep transition-colors">
              Open in Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
