---
import Icon from "../Icon.astro";
import { services } from "../../data/salon";
---

<section id="behandelingen" class="py-24 md:py-32 bg-cream-2 relative">
  <div class="container-prohair">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14 md:mb-20" data-reveal>
      <div>
        <p class="eyebrow mb-4">Behandelingen</p>
        <h2 class="font-display text-[40px] sm:text-[56px] md:text-[64px] leading-[0.98] max-w-2xl">
          Wat je hier <em class="italic text-copper">kunt doen</em>
        </h2>
      </div>
      <a href="/behandelingen" class="link-arrow">Hele behandelingenlijst <Icon name="arrow" size={14}/></a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
      {services.map((s, i) => (
        <article
          class="group relative bg-cream rounded-card p-6 md:p-7 flex flex-col h-full border border-line/70 hover:border-ink transition-all duration-500"
          data-reveal
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="flex items-center justify-between mb-8">
            <div class="w-12 h-12 rounded-full bg-cream-2 group-hover:bg-ink group-hover:text-cream inline-flex items-center justify-center transition-colors duration-500">
              <Icon name={s.icon as any} size={20}/>
            </div>
            <span class="text-[11px] uppercase tracking-[0.18em] text-ink-soft">0{i + 1}</span>
          </div>
          <h3 class="font-display text-[28px] md:text-[32px] leading-[1] mb-3">{s.title}</h3>
          <p class="text-[14px] text-ink-soft leading-[1.6] mb-6 flex-1">{s.short}</p>
          <a href={`/behandelingen#${s.slug}`} class="link-arrow !text-[13px] self-start">
            Meer over {s.title.toLowerCase()} <Icon name="arrow" size={13}/>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
