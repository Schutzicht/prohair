---
import { team } from "../../data/salon";
---

<section id="team" class="py-24 md:py-32 bg-cream-2">
  <div class="container-prohair">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14" data-reveal>
      <div>
        <p class="eyebrow mb-4">Het team</p>
        <h2 class="font-display text-[40px] sm:text-[56px] md:text-[68px] leading-[0.96] max-w-2xl">
          Zes stylisten,<br/>
          <em class="italic text-copper">een mascotte.</em>
        </h2>
      </div>
      <p class="text-[14px] text-ink-soft max-w-sm">
        Iedere stylist heeft een eigen handtekening, maar werkt vanuit dezelfde Pivot Point grondslag. Kies je favoriet, of laat je adviseren wie het beste bij jouw vraag past.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-5">
      {team.map((m: any, i: number) => (
        <article
          class="group relative bg-cream rounded-card overflow-hidden border border-line/60"
          data-reveal
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="relative aspect-[1/1] overflow-hidden bg-cream-2">
            <img
              src={m.image}
              alt={m.name}
              class="w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-105"
              loading="lazy"
            />
            {m.isMascot && (
              <div class="absolute top-3 left-3 bg-copper text-cream text-[10px] uppercase tracking-[0.18em] px-2.5 py-1 rounded-full font-medium">
                Hond
              </div>
            )}
          </div>
          <div class="p-5">
            <p class="font-display text-2xl md:text-[26px] leading-none">{m.name}</p>
            <p class="text-[11px] uppercase tracking-[0.16em] text-ink-soft mt-2">{m.role}</p>
            <p class="hidden md:block text-[13px] text-ink-soft mt-3 leading-[1.55]">{m.note}</p>
          </div>
        </article>
      ))}
      <article class="group relative bg-ink text-cream rounded-card overflow-hidden border border-ink flex flex-col" data-reveal style={`transition-delay: ${team.length * 60}ms`}>
        <div class="p-5 md:p-6 flex-1 flex flex-col justify-between min-h-[220px]">
          <p class="font-display text-2xl md:text-[26px] leading-[1.05]">
            Word jij ons<br/>
            <em class="italic text-copper-soft">volgende</em><br/>
            collega?
          </p>
          <a href="/contact?topic=werken" class="link-arrow !text-cream !border-cream/30 hover:!border-cream !text-[13px] mt-6">
            Bekijk vacatures
          </a>
        </div>
      </article>
    </div>
  </div>
</section>
