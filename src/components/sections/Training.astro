---
import Icon from "../Icon.astro";
import { trainingHighlights } from "../../data/salon";
---

<section class="py-24 md:py-32 relative">
  <div class="container-prohair">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-32" data-reveal>
        <p class="eyebrow mb-5">Kappers Opleiding Zeeland</p>
        <h2 class="font-display text-[40px] sm:text-[56px] md:text-[72px] leading-[0.96]">
          Wij zijn ook een<br/>
          <em class="italic text-copper">school.</em>
        </h2>
        <p class="mt-7 text-[16px] leading-[1.7] text-ink-soft max-w-md">
          Onder hetzelfde dak leiden we de volgende generatie kappers op via <strong class="text-ink font-medium">KOZeeland</strong>, in samenwerking met Pivot Point. Een complete praktijkopleiding plus open aanbod voor losse modules.
        </p>
        <p class="mt-4 text-[14px] leading-[1.7] text-ink-soft max-w-md">
          Niets is zo belangrijk als een goede basis. Tijdens 'The Fundamentals' bouw je in een kleine groep een portfolio op, methodisch en met resultaten die door elke werkgever erkend worden.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/trainingscentrum" class="btn-primary">Meer over KOZeeland <Icon name="arrow" size={16}/></a>
          <a href="https://www.kozeeland.nl" target="_blank" rel="noopener" class="btn-ghost">kozeeland.nl</a>
        </div>
      </div>

      <div class="lg:col-span-7 space-y-4" data-reveal>
        <div class="relative aspect-[16/10] rounded-jumbo overflow-hidden image-grain bg-cream-2">
          <img
            src="/team/kapsalon_prohair_estrella.jpg"
            alt="Kappersopleiding bij KOZeeland"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/45 to-transparent"></div>
          <div class="absolute bottom-6 left-6 right-6 flex items-end justify-between gap-4 text-cream">
            <div>
              <p class="text-[11px] uppercase tracking-[0.2em] opacity-75">The Fundamentals</p>
              <p class="font-display text-2xl md:text-3xl mt-1">Complete praktijkopleiding</p>
            </div>
            <a href="/trainingscentrum" class="hidden sm:inline-flex items-center justify-center w-12 h-12 rounded-full bg-cream text-ink hover:bg-copper-soft transition-colors">
              <Icon name="arrow" size={18}/>
            </a>
          </div>
        </div>

        <div class="grid sm:grid-cols-3 gap-3">
          {trainingHighlights.map((h) => (
            <div class="bg-cream-2 rounded-card p-5 border border-line/60 hover:bg-cream transition-colors">
              <p class="font-display text-xl leading-tight mb-2">{h.title}</p>
              <p class="text-[13px] text-ink-soft leading-[1.55]">{h.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
