---
import Icon from "../Icon.astro";
---

<section class="relative pt-28 md:pt-32 pb-20 md:pb-28 overflow-hidden">
  <div aria-hidden="true" class="absolute top-1/3 -left-40 w-[640px] h-[640px] rounded-full bg-copper/15 blur-[180px]"></div>
  <div aria-hidden="true" class="absolute bottom-0 -right-40 w-[480px] h-[480px] rounded-full bg-copper-soft/30 blur-[160px]"></div>

  <div class="container-prohair relative">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
      <div class="lg:col-span-5" data-reveal>
        <p class="eyebrow flex items-center gap-3 mb-6">
          <span class="w-8 h-px bg-ink-soft"></span>
          De leukste kapsalon van Nederland
        </p>
        <h1 class="font-display text-[44px] sm:text-[64px] md:text-[80px] lg:text-[96px] xl:text-[112px] leading-[0.92] tracking-[-0.025em]">
          Luxe voor<br/>
          <em class="italic text-copper">iedereen.</em>
        </h1>
        <p class="mt-8 max-w-xl text-[16px] md:text-[17px] leading-[1.65] text-ink-soft">
          Onze focus ligt niet alleen op mooi haar in de salon, maar ook op een coupe die jij thuis makkelijk zelf modelleert. Een kapsel dat past bij jouw type haar, gezichtskenmerken en lifestyle.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact" class="btn-primary">Ik wil een afspraak maken <Icon name="arrow" size={16}/></a>
          <a href="/behandelingen" class="btn-ghost">Bekijk behandelingen</a>
        </div>

        <div class="mt-14 flex flex-wrap items-center gap-x-6 gap-y-3 text-[11px] uppercase tracking-[0.18em] text-ink-soft">
          <div class="flex items-center gap-2">
            <span class="block w-1.5 h-1.5 rounded-full bg-copper"></span>
            L'Oreal Professionnel
          </div>
          <span class="opacity-30 hidden sm:inline">/</span>
          <div>Pivot Point methode</div>
          <span class="opacity-30 hidden sm:inline">/</span>
          <div>Eigen kappersopleiding</div>
        </div>
      </div>

      <div class="lg:col-span-7 relative" data-reveal>
        <div class="relative aspect-[4/3] md:aspect-[5/4] lg:aspect-[4/3] rounded-jumbo overflow-hidden image-grain bg-cream-2">
          <img
            src="/photos/team-groep.jpg"
            alt="Het team van ProHair Vlissingen"
            class="w-full h-full object-cover"
            style="object-position: center 30%;"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/20 via-transparent to-transparent"></div>
        </div>

        <div class="absolute -bottom-6 -left-4 sm:-left-8 bg-cream rounded-card px-5 py-4 shadow-[0_24px_60px_-20px_rgba(26,20,17,0.25)] max-w-[260px] border border-line/60">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-ink text-cream inline-flex items-center justify-center shrink-0">
              <Icon name="clock" size={18}/>
            </div>
            <div>
              <p class="text-[11px] uppercase tracking-[0.18em] text-ink-soft">Vandaag</p>
              <p class="text-sm font-medium">Geopend tot 21:00</p>
            </div>
          </div>
          <p class="mt-3 text-[12px] text-ink-soft leading-relaxed">Donderdag koopavond. De koffie staat al klaar.</p>
        </div>

        <div class="absolute top-4 right-4 bg-cream/95 backdrop-blur px-4 py-2.5 rounded-full flex items-center gap-2 text-[12px] shadow-md">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          Nieuwe klanten welkom
        </div>
      </div>
    </div>
  </div>
</section>
