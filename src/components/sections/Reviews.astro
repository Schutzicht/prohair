---
import { reviews } from "../../data/salon";
---

<section class="py-24 md:py-32">
  <div class="container-prohair">
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
      <p class="eyebrow mb-5">Klanten over ons</p>
      <h2 class="font-display text-[40px] sm:text-[56px] md:text-[68px] leading-[0.98]">
        Wij gaan voor de <em class="italic text-copper">mooiste</em> versie van jou.
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-4 md:gap-5">
      {reviews.map((r, i) => (
        <figure
          class="bg-cream-2 rounded-card p-7 md:p-8 flex flex-col border border-line/60"
          data-reveal
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="flex gap-1 text-copper">
            {Array.from({ length: 5 }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 14.6 8.6 22 9.3l-5.5 4.8L18 21l-6-3.6L6 21l1.5-6.9L2 9.3l7.4-.7Z"/></svg>
            ))}
          </div>
          <blockquote class="font-display text-[22px] md:text-[26px] leading-[1.2] mt-5 flex-1">
            &ldquo;{r.quote}&rdquo;
          </blockquote>
          <figcaption class="mt-6 pt-4 border-t border-line/60 flex items-center justify-between text-[13px]">
            <span class="font-medium">{r.author}</span>
            <span class="text-ink-soft">{r.detail}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
