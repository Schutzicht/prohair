---
import Icon from "./Icon.astro";
import { salon } from "../data/salon";
---

<footer class="bg-ink text-cream relative overflow-hidden">
  <div aria-hidden="true" class="absolute -top-32 right-1/4 w-[640px] h-[640px] rounded-full bg-copper-deep/25 blur-[160px]"></div>
  <div class="container-prohair relative">
    <div class="pt-24 pb-12">
      <div class="grid lg:grid-cols-12 gap-10 pb-16 border-b border-cream/15">
        <div class="lg:col-span-5">
          <p class="eyebrow !text-cream/60">Tot snel</p>
          <h2 class="font-display text-[42px] sm:text-[56px] md:text-[68px] leading-[0.95] mt-3">
            Loop binnen,<br/>
            ga uit als <em class="italic text-copper-soft">jezelf, plus 2%.</em>
          </h2>
          <p class="mt-6 max-w-md text-cream/70 text-[15px] leading-relaxed">
            Een eerste afspraak begint altijd met een gratis intakegesprek van 10 minuten. Zo weten we precies wat jouw haar nodig heeft, voordat de schaar in beeld komt.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact" class="btn-primary !bg-cream !text-ink hover:!bg-copper-soft">Maak afspraak <Icon name="arrow" size={16} /></a>
            <a href={salon.phoneHref} class="btn-ghost !border-cream/40 !text-cream hover:!bg-cream hover:!text-ink"><Icon name="phone" size={16} /> {salon.phone}</a>
          </div>
        </div>
        <div class="lg:col-span-7 grid sm:grid-cols-3 gap-8 lg:gap-6">
          <div>
            <p class="eyebrow !text-cream/60 mb-4">Bezoek</p>
            <p class="text-[15px] leading-relaxed">{salon.address.street}<br/>{salon.address.zip} {salon.address.city}</p>
            <a href={salon.mapsUrl} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-2 text-[13px] text-copper-soft hover:text-cream transition-colors">Route plannen <Icon name="arrow" size={14} /></a>
          </div>
          <div>
            <p class="eyebrow !text-cream/60 mb-4">Contact</p>
            <ul class="space-y-2 text-[15px]">
              <li><a href={salon.phoneHref} class="hover:text-copper-soft">{salon.phone}</a></li>
              <li><a href={`mailto:${salon.email}`} class="hover:text-copper-soft">{salon.email}</a></li>
              <li><a href={salon.facebook} target="_blank" rel="noopener" class="hover:text-copper-soft">Facebook</a></li>
            </ul>
          </div>
          <div>
            <p class="eyebrow !text-cream/60 mb-4">Openingstijden</p>
            <ul class="space-y-1.5 text-[14px]">
              {salon.hours.map((h) => (
                <li class={`flex justify-between gap-3 ${h.closed ? 'text-cream/40' : ''}`}>
                  <span>{h.day}</span><span>{h.time}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="pt-8 flex flex-col md:flex-row md:items-center justify-between gap-4 text-[12px] text-cream/45">
        <div class="flex items-center gap-3">
          <img src="/brand/prohair-logo.png" alt="ProHair" class="h-5 w-auto" style="filter: brightness(0) invert(1);" />
          <span class="opacity-60">Kapsalon & Trainingscentrum</span>
        </div>
        <div class="flex items-center gap-4">
          <span>&copy; {new Date().getFullYear()} ProHair Vlissingen</span>
          <span class="hidden md:inline opacity-40">/</span>
          <span>L'Oreal Professionnel Partner Salon</span>
        </div>
      </div>
    </div>
  </div>
</footer>
