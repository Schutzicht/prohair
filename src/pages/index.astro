---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Concept-demo voor ProHair, gemaakt door Agensea." />
    <meta name="theme-color" content="#1A1411" />
    <link rel="icon" type="image/png" href="/brand/prohair-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,30..100;1,9..144,300..700,30..100&family=Inter:wght@400;500;600&display=swap" />
    <title>Concept-demo ProHair door Agensea</title>
  </head>
  <body class="bg-ink text-cream min-h-[100svh] flex flex-col overflow-x-hidden">
    <div aria-hidden="true" class="fixed top-[-30%] right-[-30%] w-[600px] h-[600px] rounded-full bg-copper-deep/30 blur-[180px] pointer-events-none"></div>
    <div aria-hidden="true" class="fixed bottom-[-30%] left-[-30%] w-[500px] h-[500px] rounded-full bg-copper/15 blur-[160px] pointer-events-none"></div>

    <header class="relative z-10 shrink-0">
      <div class="container-prohair py-5 sm:py-6 md:py-8 flex items-center justify-between gap-3">
        <img src="/brand/prohair-logo.png" alt="ProHair" class="h-5 sm:h-6 md:h-7 w-auto" style="filter: brightness(0) invert(1);" />
        <span class="text-[10px] sm:text-[11px] uppercase tracking-[0.2em] text-cream/50">Concept &middot; niet live</span>
      </div>
    </header>

    <main class="relative z-10 flex-1 flex items-center py-8 sm:py-12">
      <div class="container-prohair w-full">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-cream/10 border border-cream/15 text-[10px] sm:text-[11px] uppercase tracking-[0.18em] text-cream/70 mb-5 sm:mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-copper-soft animate-pulse"></span>
            Een idee voor ProHair
          </div>

          <h1 class="font-display text-[40px] sm:text-[56px] md:text-[80px] lg:text-[96px] leading-[0.95] tracking-[-0.02em]">
            Zo zou jullie<br/>
            site eruit kunnen<br/>
            <em class="italic text-copper-soft">zien.</em>
          </h1>

          <p class="mt-6 sm:mt-8 max-w-xl text-[15px] sm:text-[16px] md:text-[18px] leading-[1.6] text-cream/75">
            Een vrijblijvende proeve, gebouwd door Agensea als kennismaking. Geen weggevertje, maar een voorbeeld van het werk dat we voor klanten maken. Bevalt het, dan kijken we samen wat een echte versie zou kosten.
          </p>

          <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row flex-wrap gap-3">
            <a
              href="/demo"
              class="btn-primary !bg-cream !text-ink hover:!bg-copper-soft !px-7 !py-4 !text-[15px] sm:!text-[16px] justify-center"
            >
              Bekijk de demo <Icon name="arrow" size={18}/>
            </a>
            <a
              href="mailto:info@agensea.nl"
              class="btn-ghost !border-cream/30 !text-cream hover:!bg-cream hover:!text-ink justify-center"
            >
              Liever even mailen
            </a>
          </div>

          <p class="mt-10 sm:mt-12 text-[12px] sm:text-[13px] text-cream/55 leading-[1.7] max-w-xl">
            In de mail die jullie van ons kregen staat per onderdeel wat we letterlijk hebben overgenomen uit jullie communicatie, en wat we hebben ingevuld vanuit aannames. Tijdens een eerste kop koffie maken we een offerte op maat.
          </p>
        </div>
      </div>
    </main>

    <footer class="relative z-10 border-t border-cream/10 shrink-0">
      <div class="container-prohair py-5 sm:py-6 flex flex-col gap-3 sm:flex-row sm:items-center justify-between text-[11px] sm:text-[12px] text-cream/55">
        <div>
          <p class="text-cream/80">Gemaakt door <span class="font-medium text-cream">Agensea</span>, digitaal bureau uit Zeeland.</p>
        </div>
        <div class="flex flex-wrap gap-x-4 gap-y-1">
          <a href="tel:+31681383601" class="hover:text-copper-soft">06 81 38 36 01</a>
          <span class="opacity-30">/</span>
          <a href="mailto:info@agensea.nl" class="hover:text-copper-soft">info@agensea.nl</a>
        </div>
      </div>
    </footer>
  </body>
</html>
